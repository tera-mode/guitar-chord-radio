# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — APIキー・Firebase設定などの機密情報を含むため絶対にコミット禁止
# .env.local.example のみ（値なしのテンプレート）はコミット可
.env.local
.env*.local
.env.production
.env.development
# ↓ NEXT_PUBLIC_ 付きの変数はブラウザに露出するため機密情報を入れないこと
# ↓ YOUTUBE_API_KEY は NEXT_PUBLIC_ なし（サーバーサイド専用）で使うこと

# Playwright テスト生成物
.playwright-mcp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playtest artifacts
docs/playtests/screenshots/
docs/playtests/notes/

# コード譜PDF（著作権保護のため絶対に公開禁止）
# docs/chord/ 配下のPDFは個人利用のローカル参考資料
docs/chord/
*.pdf
