# YouTube Data API v3
# Google Cloud Console > APIとサービス > 認証情報 からAPIキーを取得
# YouTube Data API v3 を有効化しておくこと
# 無料枠: 10,000ユニット/日（検索1回=100ユニット → 100検索/日）
# 一度検索した結果はローカルストレージにキャッシュされるため通常は少量で済む
YOUTUBE_API_KEY=

# Firebase Configuration
# Firebaseコンソール > プロジェクト設定 > マイアプリ > SDKの設定と構成 から取得
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
